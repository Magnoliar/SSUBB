# 临时文件
temp/
tmp/
*.tmp
audio_temp/
worker_temp/

# Python / 虚拟环境
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# IDE 与系统文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
